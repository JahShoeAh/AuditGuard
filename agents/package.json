{
  "name": "auditguard-agents",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "scanner": "tsx scanner/index.ts",
    "scanner:test": "TEST_MODE=true tsx scanner/index.ts",
    "static": "tsx static-analysis/index.ts",
    "fuzzer": "tsx fuzzer/index.ts",
    "llm": "tsx llm-contextual/index.ts",
    "dependency": "tsx dependency/index.ts",
    "report": "tsx report/index.ts",
    "alert": "tsx alert/index.ts",
    "all": "tsx run-all.ts",
    "all:test": "TEST_MODE=true tsx run-all.ts",
    "all:demo": "DEMO_MODE=true tsx run-all.ts",
    "all:demo:test": "TEST_MODE=true DEMO_MODE=true tsx run-all.ts",
    "all:legacy": "concurrently \"npm run scanner\" \"npm run static\" \"npm run fuzzer\" \"npm run llm\" \"npm run dependency\" \"npm run report\" \"npm run alert\"",
    "fund": "tsx scripts/fund-agents.ts",
    "test": "vitest run --reporter=verbose",
    "test:invite": "vitest run tests/auction-invite.test.ts --reporter=verbose",
    "test:token-transfer": "node --import tsx test-token-transfer.ts",
    "test:staking": "node --import tsx test-staking.ts",
    "test:rewards": "node --import tsx test-rewards.ts",
    "test:ipfs": "node --import tsx test-ipfs.ts",
    "test:zg:diagnostics": "node --import tsx test-zg-diagnostics.ts",
    "test:zg:integration": "node --import tsx test-zg-integration.ts",
    "test:zg:model-update": "node --import tsx test-model-update.ts"
  },
  "dependencies": {
    "@0glabs/0g-serving-broker": "^0.7.1",
    "@anthropic-ai/sdk": "^0.38.0",
    "@hashgraph/sdk": "^2.24.0",
    "dotenv": "^16.4.0",
    "ethers": "^6.13.0",
    "evmdecoder": "^0.0.69",
    "hashconnect": "0.2.9",
    "vite": "7.3.1",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "concurrently": "^8.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "4.0.18"
  }
}
