# Required: Hedera account that signs HCS messages and on-chain txs.
# Create/import this account in HashPack or another Hedera-compatible wallet.
UCP_AGENT_ACCOUNT_ID=0.0.123456

# Required: ECDSA private key for UCP_AGENT_ACCOUNT_ID (hex, with or without 0x).
# Export from your wallet, or use a dedicated testnet automation key.
UCP_AGENT_PRIVATE_KEY=0xYOUR_ECDSA_PRIVATE_KEY

# Strongly recommended: public HTTPS endpoint reachable by orchestrator/dashboard.
# Use ngrok/cloudflared, e.g. `ngrok http 3737` then paste the HTTPS forwarding URL.
UCP_AGENT_ENDPOINT=https://your-agent.ngrok-free.app

# Optional identity metadata (defaults shown).
UCP_AGENT_ID=ucp-example-001
UCP_AGENT_PORT=3737
UCP_AGENT_STAKE_GUARD=100
UCP_AGENT_REPUTATION=1000
UCP_AGENT_SPECIALIZATIONS=any
UCP_SKIP_ONCHAIN_REGISTER=false

# Optional HCS topic overrides.
# Defaults resolve from ../../packages/sdk/config.json -> hcsTopics.*
UCP_AGENT_COMMS_TOPIC_ID=
UCP_AUDIT_LOG_TOPIC_ID=

# Optional contract address overrides.
# Defaults resolve from ../../packages/sdk/config.json.
UCP_AUCTION_ADDRESS=
UCP_AGENT_REGISTRY_ADDRESS=
UCP_GUARD_TOKEN_ADDRESS=
