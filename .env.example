# ============================================================
# AuditGuard — Environment Variables (Hedera Testnet)
# Copy this file to .env — these are shared testnet keys, safe to commit.
# Credential authority: root .env is canonical for *_ACCOUNT_ID / *_PRIVATE_KEY.
# agents/.env is for agent tuning; credential overrides there are ignored by default.
# ============================================================

# ============================================
# HEDERA TESTNET CREDENTIALS
# Used by packages/contracts (Hardhat) and packages/inft.
# ============================================
HEDERA_ACCOUNT_ID=0.0.7951944
HEDERA_PRIVATE_KEY=
HEDERA_PRIVATE_KEY_TYPE=ECDSA
HEDERA_NETWORK=testnet
HEDERA_JSON_RPC_URL=https://testnet.hashio.io/api

# ============================================
# OPERATOR CREDENTIALS
# Shared fallback for orchestrator + agents.
# ============================================
OPERATOR_ACCOUNT_ID=0.0.7951944
OPERATOR_PRIVATE_KEY=

# ============================================
# PER-AGENT HEDERA ACCOUNTS
# ============================================

# Agent 1: Scanner
# NOTE: when STRICT_LIVE=true, scanner payer must be different from orchestrator/operator payer.
SCANNER_ACCOUNT_ID=0.0.7951944
SCANNER_PRIVATE_KEY=

# Agent 2: Static Analysis
STATIC_ACCOUNT_ID=0.0.7951945
STATIC_PRIVATE_KEY=

# Agent 3: Fuzzer
FUZZER_ACCOUNT_ID=0.0.7951946
FUZZER_PRIVATE_KEY=

# Agent 4: LLM Contextual
LLM_ACCOUNT_ID=0.0.7951947
LLM_PRIVATE_KEY=
# Agent 5: Dependency
DEPENDENCY_ACCOUNT_ID=0.0.7951948
DEPENDENCY_PRIVATE_KEY=

# Agent 6: Report
REPORT_ACCOUNT_ID=0.0.7951949
REPORT_PRIVATE_KEY=

# Agent 7: Alert
ALERT_ACCOUNT_ID=0.0.7951955
ALERT_PRIVATE_KEY=

# ============================================
# MODE
# ============================================
DEMO_MODE=false
STRICT_LIVE=false
NO_FALLBACK_MODE=true
ALLOW_SHARED_PAYER=false
ALLOW_ENV_CREDENTIAL_DRIFT=false
ALLOW_AGENT_ENV_CREDENTIAL_OVERRIDE=false

# ============================================
# DASHBOARD INGESTION POLICY (frontend)
# ============================================
DASHBOARD_SOURCE_MODE=onchain_strict
DASHBOARD_HCS_REPLAY_MODE=from_now
VITE_DASHBOARD_SOURCE_MODE=onchain_strict
VITE_DASHBOARD_HCS_REPLAY_MODE=from_now
VITE_ACTIVE_JOBS_POLL_MS=3000

# ============================================
# BID COLLATERAL AUTO TOP-UP (GUARD)
# ============================================
BID_GUARD_AUTO_TOPUP_ENABLED=true
BID_GUARD_AUTO_TOPUP_DONOR_KEYS=SCANNER_PRIVATE_KEY,STATIC_PRIVATE_KEY,FUZZER_PRIVATE_KEY,LLM_PRIVATE_KEY,DEPENDENCY_PRIVATE_KEY,REPORT_PRIVATE_KEY,ALERT_PRIVATE_KEY,OPERATOR_PRIVATE_KEY,AGENT_REGISTRY_OWNER_PRIVATE_KEY,HEDERA_PRIVATE_KEY
BID_GUARD_AUTO_TOPUP_BUFFER_GUARD=50
BID_GUARD_AUTO_TOPUP_DONOR_MIN_GUARD=200
BID_GUARD_AUTO_TOPUP_MAX_TRANSFER_GUARD=500

# ============================================
# BID GAS AUTO TOP-UP (HBAR)
# ============================================
BID_HBAR_AUTO_TOPUP_ENABLED=true
BID_HBAR_AUTO_TOPUP_DONOR_KEYS=SCANNER_PRIVATE_KEY,STATIC_PRIVATE_KEY,FUZZER_PRIVATE_KEY,LLM_PRIVATE_KEY,DEPENDENCY_PRIVATE_KEY,REPORT_PRIVATE_KEY,ALERT_PRIVATE_KEY,OPERATOR_PRIVATE_KEY,AGENT_REGISTRY_OWNER_PRIVATE_KEY,HEDERA_PRIVATE_KEY
BID_HBAR_AUTO_TOPUP_MIN_HBAR=0.25
BID_HBAR_AUTO_TOPUP_TARGET_HBAR=1.00
BID_HBAR_AUTO_TOPUP_DONOR_MIN_HBAR=1.50
BID_HBAR_AUTO_TOPUP_MAX_TRANSFER_HBAR=2.00

# ============================================
# ORCHESTRATOR HARDENING
# ============================================
ORCHESTRATOR_ROSTER_BOOTSTRAP_ONCHAIN=true
ORCHESTRATOR_ENABLE_DISCOVERY_DEDUPE=true
ORCHESTRATOR_DISCOVERY_DEDUPE_TTL_MS=120000
ORCHESTRATOR_FILTER_INVITES_ONCHAIN_ACTIVE=true
ORCHESTRATOR_ACTIVE_CHECK_RETRIES=3
ORCHESTRATOR_ACTIVE_CHECK_FAIL_OPEN=false
ORCHESTRATOR_AUCTION_CLOSE_SINGLEFLIGHT=true
ORCHESTRATOR_RECONCILE_EXPIRED_AUCTIONS=true
ORCHESTRATOR_RECONCILE_EXPIRED_AUCTIONS_INTERVAL_MS=30000
ORCHESTRATOR_RECONCILE_MAX_CLOSES_PER_CYCLE=3
ORCHESTRATOR_RECONCILE_FAILURE_COOLDOWN_MS=15000
ORCHESTRATOR_AUTO_TOPUP_HBAR=true
ORCHESTRATOR_MIN_HBAR=0.5
ORCHESTRATOR_TARGET_HBAR=2

# ============================================
# WEBHOOKS (optional)
# ============================================
DISCORD_WEBHOOK_URL=
ALERT_WEBHOOK_URL=

# ============================================
# CLOUDFLARE EVENT RELAY (optional)
# If set, every successful HCS publish is mirrored to /api/events.
# ============================================
EVENT_RELAY_URL=
EVENT_RELAY_TOKEN=

# Dashboard event API source (Cloudflare Worker)
# For shared-domain routing this should stay "/api".
VITE_EVENTS_API_BASE_URL=/api

# ============================================
# 0g COMPUTE NETWORK — LLM Inference
# Powers the LLM Contextual Agent via @0glabs/0g-serving-broker SDK.
# ZG_DEPOSIT_AMOUNT — 0G tokens to pre-deposit for inference credits.
# ZG_ENABLED=false  — Force mock fallback (useful for CI / offline dev).
# ============================================
ZG_PRIVATE_KEY==
ZG_RPC_URL=https://evmrpc-testnet.0g.ai
ZG_PROVIDER_ADDRESS=0xa48f01287233509FD694a22Bf840225062E67836
ZG_MODEL=qwen/qwen-2.5-7b-instruct
ZG_DEPOSIT_AMOUNT=1
ZG_ENABLED=true
ZG_REQUIRED_IN_LIVE=true
# pinned=use configured model (alias-safe), auto=use provider metadata model, hybrid=prefer configured then auto-correct
ZG_PROVIDER_MODE=pinned
ZG_HEALTHCHECK_TIMEOUT_MS=15000
ZG_REQUEST_TIMEOUT_MS=30000
ZG_MAX_INIT_RETRIES=2
ZG_PROBE_AT_STARTUP=true
ZG_MIN_LEDGER_CREDITS=1
ZG_BROKER_LOADER_MODE=auto

# ============================================
# 0g STORAGE — iNFT metadata (packages/inft, only for Day 4)
# ============================================
ZG_EVM_RPC=https://evmrpc-testnet.0g.ai
ZG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai
ZG_KV_RPC=https://kv-testnet.0g.ai
