{
  "name": "@auditguard/cloudflare-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npx wrangler dev --local",
    "dev:remote": "npx wrangler dev",
    "db:create": "npx wrangler d1 create auditguard-events",
    "db:migrate:local": "npx wrangler d1 migrations apply auditguard-events --local",
    "db:migrate:remote": "npx wrangler d1 migrations apply auditguard-events --remote",
    "deploy:cf": "npx wrangler deploy",
    "size:worker": "npx wrangler deploy --dry-run --outdir .wrangler-dry-run"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
