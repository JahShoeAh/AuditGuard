{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "auditguard-dashboard",
  "compatibility_date": "2026-02-20",
  // Naming convention:
  // - Dashboard worker: auditguard-dashboard
  // - Canonical dashboard path: https://auditguard.<your-domain>/dashboard
  // Optional custom-domain route example:
  // "routes": [{ "pattern": "auditguard.<your-domain>/dashboard*", "zone_name": "<your-domain>" }],
  "assets": {
    "directory": "./dist"
  }
}
